'min-test require :test
;;;

"dstore" test.describe

  ("dstore.json" dsinit type "dict:datastore" ==) test.assert
  
  (
    "dstore.json" dsread :ds
    ds "tests"
    {}
      1 "test1" dset
      2 "test2" dset
    dspost dswrite
    "tests" (stack.pop true) dsquery size 1 ==
  ) test.assert
  
  (
    "dstore.json" dsread :ds
    ds "tests/aaa"
    {}
      1 "test1" dset
      3 "test3" dset
    dsput dswrite
    "tests" ("test1" dget 1 ==) dsquery size 2 ==
  ) test.assert
  
  (
    "dstore.json" dsread :ds
    ds "tests/aaa" dsdelete
    "tests" ("id" dget "aaa" ==) dsquery size 0 ==
  ) test.assert
  
  "dstore.json" rm

  test.report
  stack.clear
